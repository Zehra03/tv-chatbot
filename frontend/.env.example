# Backend base URL. MSW (sahte backend) aktifken boş bırakılabilir;
# istekler aynı origin'e gider ve mock worker tarafından yakalanır.
VITE_API_BASE_URL=

# Sahte backend'i (MSW) aç/kapat. Gerçek backend'e geçerken "false" yap
# ve VITE_API_BASE_URL'i backend adresine ayarla — kod değişikliği gerekmez.
VITE_ENABLE_MSW=true
