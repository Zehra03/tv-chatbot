# Project
PROJECT_NAME=paxassist
COMPANY_NAME=paximum.com

# Postgres
POSTGRES_DB=paxassist
POSTGRES_USER=paxassist_user
POSTGRES_PASSWORD=paxassist_password
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
# SPRING_PROFILES_ACTIVE=dev (Ollama aktif) veya dev,mock-ai (Ollama pasif/mock)
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/paxassist
SPRING_DATASOURCE_USERNAME=paxassist_user
SPRING_DATASOURCE_PASSWORD=paxassist_password
OLLAMA_BASE_URL=http://ollama:11434
AI_PROVIDER_MODEL=gemma3:4b
FRONTEND_ORIGIN=http://localhost:5173
TOURVISIO_URL=change-me
TOURVISIO_CULTURE=en-US
TOURVISIO_TIMEZONE=Europe/Istanbul
TOURVISIO_AGENCY=change-me
TOURVISIO_USER=change-me
TOURVISIO_PASSWORD=change-me

# Auth (JWT) — override with a long random secret in any shared/deployed environment.
AUTH_JWT_SECRET=change-me-32-bytes-minimum-random-secret
AUTH_JWT_EXPIRATION_MINUTES=60

# Frontend
# Bu blok yalnizca docker compose'daki (su an devre disi) frontend servisinin
# build arg'i icindir. Lokal frontend gelistirmede frontend/.env kullanilir:
# frontend/.env.example'i kopyala — VITE_ENABLE_MSW orada yasar (yalnizca dev;
# production bundle'ina girmez) ve MSW acikken VITE_API_BASE_URL bos birakilir.
# NOT: /api/v1 oneki EKLENMEZ — endpoint modulleri yolu zaten iceriyor.
VITE_API_BASE_URL=http://localhost:8080
FRONTEND_PORT=5173

# Redis
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# TourVisio API
TOURVISIO_API_URL=https://test-service.tourvisio.com/v2
TOURVISIO_API_AGENCY=INTERNSHIP
TOURVISIO_API_USER=INTERNSHIP
TOURVISIO_API_PASSWORD=1
