# Project
PROJECT_NAME=paxassist
COMPANY_NAME=paximum.com

# Postgres
POSTGRES_DB=paxassist
POSTGRES_USER=paxassist_user
POSTGRES_PASSWORD=paxassist_password
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
# Profiller — normal calismada BOS birakin:
#   (bos) = HER SEY GERCEK: hotel/flight canli TourVisio (TOURVISIO_* kimlik ister),
#           sohbet + niyet cikarimi Gemini (GEMINI_API_KEY ister), Postgres+Flyway, Redis.
#   demo  = hotel/flight MOCK verisi, altyapi gercek (TourVisio kimligi gerekmez).
#   mock  = CI baglam testi (AI/TourVisio mock, Flyway kapali)
SPRING_PROFILES_ACTIVE=
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/paxassist
SPRING_DATASOURCE_USERNAME=paxassist_user
SPRING_DATASOURCE_PASSWORD=paxassist_password
# Yalnizca VALIDATOR_PROVIDER=ollama iken okunur (bugun: mock/mock-ai/loadtest test profilleri).
# Varsayilan validator (deepseek) ve Gemini bunu kullanmaz.
OLLAMA_BASE_URL=http://ollama:11434
# Ana sohbet + niyet cikarimi Google Gemini (OpenAI-uyumlu endpoint) uzerinde calisir.
# AI_PROVIDER_MODEL = Gemini model adi (application.yml varsayilani: gemini-flash-latest).
AI_PROVIDER_MODEL=gemini-flash-latest
# aistudio.google.com/apikey — kendi anahtarinizi alin, git'e ASLA girmez.
# Anahtari paylasirsaniz kota/rate limit'i birlikte tuketirsiniz.
GEMINI_API_KEY=change-me
FRONTEND_ORIGIN=http://localhost:5173
# TourVisio — bunlar backend'in okuduğu kanonik adlardır (application.yml: ${TOURVISIO_*}).
# TOURVISIO_URL = host+versiyon tabanı, /api EKLENMEZ (istemciler /api'yi kendi ekler).
TOURVISIO_URL=https://test-service.tourvisio.com/v2
TOURVISIO_CULTURE=en-US
TOURVISIO_TIMEZONE=Europe/Istanbul
TOURVISIO_AGENCY=change-me
TOURVISIO_USER=change-me
TOURVISIO_PASSWORD=change-me

# Auth (JWT) — override with a long random secret in any shared/deployed environment.
AUTH_JWT_SECRET=change-me-32-bytes-minimum-random-secret
AUTH_JWT_EXPIRATION_MINUTES=60
# Refresh token lifetime (DB-persisted, rotated per use, revoked on logout).
AUTH_REFRESH_EXPIRATION_DAYS=30

# Validator (ikinci katman LLM denetimi). Varsayilan provider "deepseek" + "deepseek-chat" —
# A/B testi sonucu onerilen uretim konfigurasyonu (~$0.0002/mesaj, +~2sn).
# DEEPSEEK_API_KEY zorunludur; verilmezse backend acilista hata verir (fail-fast).
# (mock/mock-ai/loadtest test profilleri provider=ollama'ya sabitlidir, CI icin anahtar gerekmez.)
DEEPSEEK_API_KEY=change-me          # platform.deepseek.com — asla commit etmeyin
#VALIDATOR_MODEL=deepseek-chat      # 2026-07-24'te deprecate -> deepseek-v4-flash'a gecin
# Tamamen yerel / ek maliyetsiz calismak icin Ollama'ya donebilirsiniz:
#   VALIDATOR_PROVIDER=ollama
#   VALIDATOR_MODEL=gemma3:4b

# Frontend
# Bu blok yalnizca docker compose'daki (su an devre disi) frontend servisinin
# build arg'i icindir. Lokal frontend gelistirmede frontend/.env kullanilir:
# frontend/.env.example'i kopyala — VITE_ENABLE_MSW orada yasar (yalnizca dev;
# production bundle'ina girmez) ve MSW acikken VITE_API_BASE_URL bos birakilir.
# NOT: /api/v1 oneki EKLENMEZ — endpoint modulleri yolu zaten iceriyor.
VITE_API_BASE_URL=http://localhost:8080
FRONTEND_PORT=5173

# Redis — backend SPRING_REDIS_* okur (REDIS_HOST/REDIS_PORT DEĞİL). Docker'da host = servis adı "redis".
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# NOT: Eski TOURVISIO_API_* ve REDIS_* adları backend'de OKUNMAZ; kanonik adlar yukarıdadır.
# Gerçek INTERNSHIP kimlik bilgilerini (agency/user/password) yalnızca .env'e yazın, buraya değil.
