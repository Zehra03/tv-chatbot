{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "shadcn": {
      "command": "cmd",
      "args": ["/c", "cd /d \"%CLAUDE_PROJECT_DIR%\\frontend\" && npx -y shadcn@latest mcp"]
    },
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest", "API_KEY=${MAGIC_API_KEY}"]
    }
  }
}
