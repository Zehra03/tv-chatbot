{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "shadcn": {
      "command": "cmd",
      "args": ["/c", "frontend\\shadcn-mcp.cmd"]
    },
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest", "API_KEY=${MAGIC_API_KEY}"]
    }
  }
}
